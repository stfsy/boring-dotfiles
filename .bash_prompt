# Adapted from http://gist.github.com/31934
# http://henrik.nyh.se/2008/12/git-dirty-prompt
# http://www.simplisticcomplexity.com/2008/03/13/show-your-git-branch-name-in-your-prompt/
        RED="\[\033[0;31m\]"
     ORANGE="\[\033[0;33m\]"
     YELLOW="\[\033[0;33m\]"
      GREEN="\[\033[0;32m\]"
       BLUE="\[\033[0;34m\]"
  LIGHT_RED="\[\033[1;31m\]"
LIGHT_GREEN="\[\033[1;32m\]"
      WHITE="\[\033[1;37m\]"
 LIGHT_GRAY="\[\033[0;37m\]"
 COLOR_NONE="\[\e[0m\]"

function git_info {
  # Fast check for git repo
  local git_dir=$(git rev-parse --git-dir 2> /dev/null)
  [[ -z "$git_dir" ]] && return

  # Get branch name and status in one porcelain call (faster)
  local status_output=$(git status --porcelain --branch 2> /dev/null)
  local branch=$(echo "$status_output" | grep "##" | sed 's/## //;s/\.\.\..*//')
  
  local state=""
  local remote=""

  # Remote status logic
  if echo "$status_output" | grep -q 'ahead'; then
    remote=" ${GREEN}↑"
  elif echo "$status_output" | grep -q 'behind'; then
    remote=" ${GREEN}↓"
  elif echo "$status_output" | grep -q 'diverged'; then
    remote=" ${YELLOW}↑↓"
  fi

  # Return formatted string as per your original visual style
  echo -e "${RED} ᚴ ${branch}${remote}${state}${COLOR_NONE}"
}

function python_env() {
  if [[ -n "$VIRTUAL_ENV" ]] ; then
    # Kept your specific snake emoji and spacing
    echo -e " 🐍"
  fi
}

function prompt_func() {
    local exit_code=$?
    
    # Meaningful exit code indicator
    local symbol_color="${WHITE}"
    if [[ $exit_code -ne 0 ]]; then
        symbol_color="${RED}"
    fi

    # \w = working directory
    # Rebuilding your original structure: [path][git][python] ❯ 
    PS1="\n${COLOR_NONE}\w$(git_info)$(python_env) ${symbol_color}❯${COLOR_NONE} "
}

PROMPT_COMMAND=prompt_func 
LANG=C.UTF-8