{
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[terraform-vars]": {
        "editor.codeActionsOnSave": {
            "source.formatAll.terraform": "explicit"
        },
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": false
    },
    "[terraform]": {
        "editor.codeActionsOnSave": {
            "source.formatAll.terraform": "explicit"
        },
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": false
    },
    "[vue]": {
        "editor.defaultFormatter": "Vue.volar"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "chat.commandCenter.enabled": true,
    "cloudcode.enableTelemetry": false,
    "cloudcode.project": "discue-io",
    "continue.enableTabAutocomplete": false,
    "continue.telemetryEnabled": false,
    "diffEditor.codeLens": true,
    "diffEditor.ignoreTrimWhitespace": true,
    "editor.accessibilitySupport": "off",
    "editor.autoClosingBrackets": "always",
    "editor.codeActionsOnSave": {
        "source.fixAll": "always",
        "source.fixAll.eslint": "always",
        "source.fixAll.pylance": "always",
        "source.organizeImports": "always",
        "source.unusedImports": "always"
    },
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.inlineSuggest.enabled": true,
    "editor.minimap.enabled": false,
    "editor.renderControlCharacters": true,
    "editor.renderFinalNewline": "on",
    "editor.renderWhitespace": "all",
    "editor.suggest.preview": true,
    "editor.tabCompletion": "on",
    "geminicodeassist.enable": true,
    "geminicodeassist.enableTelemetry": false,
    "geminicodeassist.inlineSuggestions.enableAuto": true,
    "geminicodeassist.project": "discue-io",
    "git.openRepositoryInParentFolders": "never",
    "git.suggestSmartCommit": false,
    "go.useLanguageServer": true,
    "html.format.wrapAttributes": "force-aligned",
    "javascript.preferences.importModuleSpecifierEnding": "js",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "mdb.sendTelemetry": false,
    "mergeEditor.diffAlgorithm": "advanced",
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "notebook.lineNumbers": "on",
    "redhat.telemetry.enabled": false,
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.allowChords": false,
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.scrollback": 10000,
    "terraform.codelens.referenceCount": true,
    "terraform.experimentalFeatures.prefillRequiredFields": true,
    "terraform.languageServer.enable": true,
    "terraform.validation.enableEnhancedValidation": false,
    "typescript.preferences.importModuleSpecifierEnding": "js",
    "window.commandCenter": true,
    "window.menuBarVisibility": "toggle",
    "window.zoomLevel": -1,
    "workbench.editor.showTabs": "single",
    "workbench.startupEditor": "none",
    "yaml.customTags": [
        "!And scalar",
        "!And mapping",
        "!And sequence",
        "!If scalar",
        "!If mapping",
        "!If sequence",
        "!Not scalar",
        "!Not mapping",
        "!Not sequence",
        "!Equals scalar",
        "!Equals mapping",
        "!Equals sequence",
        "!Or scalar",
        "!Or mapping",
        "!Or sequence",
        "!FindInMap scalar",
        "!FindInMap mapping",
        "!FindInMap sequence",
        "!Base64 scalar",
        "!Base64 mapping",
        "!Base64 sequence",
        "!Cidr scalar",
        "!Cidr mapping",
        "!Cidr sequence",
        "!Ref scalar",
        "!Ref mapping",
        "!Ref sequence",
        "!Sub scalar",
        "!Sub mapping",
        "!Sub sequence",
        "!GetAtt scalar",
        "!GetAtt mapping",
        "!GetAtt sequence",
        "!GetAZs scalar",
        "!GetAZs mapping",
        "!GetAZs sequence",
        "!ImportValue scalar",
        "!ImportValue mapping",
        "!ImportValue sequence",
        "!Select scalar",
        "!Select mapping",
        "!Select sequence",
        "!Split scalar",
        "!Split mapping",
        "!Split sequence",
        "!Join scalar",
        "!Join mapping",
        "!Join sequence"
    ],
    "chat.agent.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false,
        "vue": true,
        "javascript": true,
        "go": true,
        "instructions": true
    },
    "vue.autoInsert.dotValue": true,
    "docker.extension.enableComposeLanguageServer": false,
    "mdb.mcp.server": "prompt",
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "chat.tools.terminal.autoApprove": {
        "cd": true,
        "echo": true,
        "ls": true,
        "pwd": true,
        "cat": true,
        "head": true,
        "tail": true,
        "findstr": true,
        "wc": true,
        "tr": true,
        "cut": true,
        "cmp": true,
        "which": true,
        "basename": true,
        "dirname": true,
        "realpath": true,
        "readlink": true,
        "stat": true,
        "file": true,
        "du": true,
        "df": true,
        "sleep": true,
        "git status": true,
        "git log": true,
        "git show": true,
        "git diff": true,
        "column": true,
        "/^column\\b.*-c\\s+[0-9]{4,}/": false,
        "date": true,
        "/^date\\b.*(-s|--set)\\b/": false,
        "find": true,
        "/^find\\b.*-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
        "grep": true,
        "/^grep\\b.*-(f|P)\\b/": false,
        "sort": true,
        "/^sort\\b.*-(o|S)\\b/": false,
        "tree": true,
        "/^tree\\b.*-o\\b/": false,
        "rm": false,
        "rmdir": false,
        "del": false,
        "ri": false,
        "rd": false,
        "erase": false,
        "dd": false,
        "kill": false,
        "ps": false,
        "top": false,
        "Stop-Process": false,
        "spps": false,
        "taskkill": false,
        "taskkill.exe": false,
        "curl": false,
        "wget": false,
        "Invoke-RestMethod": false,
        "Invoke-WebRequest": false,
        "irm": false,
        "iwr": false,
        "chmod": false,
        "chown": false,
        "Set-ItemProperty": false,
        "sp": false,
        "Set-Acl": false,
        "jq": false,
        "xargs": false,
        "eval": false,
        "Invoke-Expression": false,
        "iex": false,
        "npm run test:unit --silent": {
            "approve": true,
            "matchCommandLine": true
        },
        "npm run test:unit -- --coverage --silent": {
            "approve": true,
            "matchCommandLine": true
        },
        "./test.sh": true,
        "gofmt": {
            "approve": true,
            "matchCommandLine": false
        },
        "/^go build \\./\\.\\.\\.$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^go mod download$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^go list -m all$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^go list -m all -mod=mod$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "go.toolsManagement.autoUpdate": true,
    "workbench.colorTheme": "Dark Modern",
}
